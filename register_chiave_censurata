        supabase.table("doctors").update({
            "password_hash": pw_hash
        }).eq("username", username).execute()

        print()
        print_green_bold_center("PASSWORD AGGIORNATA CON SUCCESSO!")
        print(f"Il Dr. {username} puo' ora accedere con la nuova password")
        print()

    except Exception as e:
        print(f"Errore: {e}")


